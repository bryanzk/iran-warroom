{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/infrastructure-status.schema.json",
  "title": "InfrastructureStatus",
  "type": "object",
  "additionalProperties": false,
  "required": ["sector", "status", "evidence", "last_updated"],
  "properties": {
    "sector": {
      "type": "string",
      "enum": [
        "airport",
        "port",
        "power",
        "communications",
        "transport",
        "financial",
        "education",
        "healthcare"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["normal", "restricted", "disrupted", "unknown"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_url", "source_time", "title", "verification_status"],
        "properties": {
          "source_url": { "type": "string", "format": "uri" },
          "source_time": { "type": "string", "format": "date-time" },
          "title": { "type": "string", "maxLength": 200 },
          "note": { "type": "string", "maxLength": 300 },
          "verification_status": {
            "type": "string",
            "enum": ["verified", "unverified", "contested"]
          }
        }
      }
    },
    "last_updated": { "type": "string", "format": "date-time" }
  }
}
