{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/event.schema.json",
  "title": "Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "timestamp",
    "location",
    "category",
    "description",
    "source_url",
    "source_time",
    "confidence",
    "verification_status"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_[a-z0-9_-]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lng", "country", "admin_level_1", "admin_level_2"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "country": { "type": "string", "const": "Iran" },
        "admin_level_1": { "type": "string" },
        "admin_level_2": { "type": "string" }
      }
    },
    "category": {
      "type": "string",
      "enum": [
        "explosion",
        "power_outage",
        "infrastructure_disruption",
        "transport_disruption",
        "communication_disruption",
        "financial_disruption",
        "official_statement",
        "other"
      ]
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "source_url": { "type": "string", "format": "uri" },
    "source_time": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verification_status": {
      "type": "string",
      "enum": ["verified", "unverified", "contested"]
    }
  }
}
